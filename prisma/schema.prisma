generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("student")
  skills        String?
  avatar        String?
  headline      String?
  banner        String?
  bio           String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  projects      Project[]
  applications  Application[]
  sentConnections   Connection[] @relation("SentConnections")
  receivedConnections Connection[] @relation("ReceivedConnections")
  
  // Learning Module Relations
  learningProgress UserLearningProgress[]
  topicProgress    UserTopicProgress[]
  savedResources   UserSavedResource[]
  studyPlans       UserStudyPlan[]

  // Messaging Relations
  chatParticipants ChatParticipant[]
  sentMessages     ChatMessage[]
  
  @@map("users")
}

model ChatConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_conversations")
}

model ChatParticipant {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  conversationId String   @map("conversation_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("chat_participants")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  level       String   @default("beginner")
  duration    String
  category    String   @default("general")
  image       String?
  createdAt   DateTime @default(now()) @map("created_at")

  enrollments Enrollment[]

  @@map("courses")
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  courseId   String   @map("course_id")
  progress  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Project {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  title               String
  description         String
  githubLink          String?  @map("github_link")
  
  // GitHub Metadata
  stars               Int      @default(0)
  forks               Int      @default(0)
  languages           String?  // Comma separated
  lastUpdated         DateTime? @map("last_updated")
  owner               String?
  repoName            String?  @map("repo_name")
  repoImage           String?  @map("repo_image")
  readme              String?  // Truncated if necessary
  
  // AI Analysis & Feedback
  difficulty          String?  // Beginner, Intermediate, Advanced
  portfolioScore      Int?     @map("portfolio_score")
  aiExplanation       String?  @map("ai_explanation")
  resumeBullets       String?  @map("resume_bullets")
  interviewQuestions  String?  @map("interview_questions")
  suggestedImprovements String? @map("suggested_improvements")
  missingFeatures     String?  @map("missing_features")
  
  score               Int?     // Legacy field
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Connection {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("SentConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("connections")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String
  description String
  applyUrl    String   @map("apply_url")
  salary      String?
  postedAt    DateTime @default(now()) @map("posted_at")

  applications Application[]

  @@map("jobs")
}

model Application {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  jobId     String   @map("job_id")
  status    String   @default("applied")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("applications")
}

// --- LEARNING MODULE SCHEMA ---

model LearningPath {
  id          String   @id @default(cuid())
  title       String   // e.g., "Software Developer", "Data Scientist"
  description String
  image       String?
  modules     LearningModule[]
  userProgress UserLearningProgress[]

  @@map("learning_paths")
}

model LearningModule {
  id             String   @id @default(cuid())
  learningPathId String
  title          String   // e.g., "Frontend Basics", "Advanced Python"
  order          Int
  topics         LearningTopic[]
  
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@map("learning_modules")
}

model LearningTopic {
  id               String   @id @default(cuid())
  moduleId         String
  title            String   // e.g., "HTML & CSS", "Neural Networks"
  description      String?
  order            Int      @default(0)
  contentMarkdown  String?  // Quick notes/summary
  videoId          String?  // YouTube ID
  resources        LearningResource[]
  
  module           LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userProgress     UserTopicProgress[]

  @@map("learning_topics")
}

model LearningResource {
  id        String   @id @default(cuid())
  topicId   String
  title     String
  type      String   // "article", "video", "practice", "interview"
  url       String
  isFree    Boolean  @default(true)
  platform  String?
  
  topic     LearningTopic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  savedBy   UserSavedResource[]

  @@map("learning_resources")
}

model UserLearningProgress {
  id             String   @id @default(cuid())
  userId         String
  learningPathId String
  status         String   @default("in_progress") // "in_progress", "completed"
  startedAt      DateTime @default(now())
  
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
  @@map("user_learning_progress")
}

model UserTopicProgress {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  isCompleted Boolean @default(false)
  completedAt DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     LearningTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@map("user_topic_progress")
}

model UserSavedResource {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  resourceId String   @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@map("user_saved_resources")
}

model UserStudyPlan {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  targetRole String   @map("target_role")
  skillLevel String   @map("skill_level")
  dailyTime  String   @map("daily_time")
  planJson   String   @map("plan_json") // Storing generic JSON for the plan structure
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_study_plans")
}
